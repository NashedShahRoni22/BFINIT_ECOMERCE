{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git add .": "allow",
      "git commit *": "allow",
      "git push": "allow",
      "git push *": "allow"
    },
    "edit": "allow"
  }
}
